#!/bin/bash

# Pre-push hook to verify build succeeds before pushing
# This prevents pushing broken code that will fail on Vercel

echo "🔍 Running pre-push build verification..."

# Run build
npm run build

if [ $? -eq 0 ]; then
    echo "✅ Build passed - safe to push"
    exit 0
else
    echo ""
    echo "❌ BUILD FAILED - Push blocked!"
    echo "Fix the build errors before pushing to prevent Vercel deployment failures."
    echo ""
    exit 1
fi
